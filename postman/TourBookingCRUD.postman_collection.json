          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["const json = pm.response.json();", "pm.collectionVariables.set('provinceId', json.id);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"code\": \"PRV{{runSuffix}}\",\n  \"name\": \"Northern Demo {{runSuffix}}\"\n}" },
