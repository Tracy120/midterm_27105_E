  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('runSuffix')) pm.collectionVariables.set('runSuffix', Date.now().toString().slice(-6));",
          "function plusDays(days){const d=new Date();d.setDate(d.getDate()+days);return d.toISOString().slice(0,10);}",
          "pm.collectionVariables.set('travelDate1', plusDays(7));",
          "pm.collectionVariables.set('travelDate2', plusDays(14));",
          "pm.collectionVariables.set('travelDate3', plusDays(21));"
        ]
      }
    }
  ],
  "variable": [
